# MongoDB Atlas үшін үлгі (Connect → Drivers ішіндегі URI-ны қойыңыз)
# Парольде @ немесе : болса, оларды URL encode етіңіз (мысалы @ → %40)

USE_MEMORY_DB=false
MONGO_URI=mongodb+srv://USERNAME:PASSWORD@cluster0.xxxxx.mongodb.net/pharm-app?retryWrites=true&w=majority
JWT_SECRET=super_secret_key
PORT=5000
